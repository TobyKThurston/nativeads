# NativeAds — environment template. Copy to .env.local and fill what you have.
# The app runs end-to-end with NONE of these set (heuristics + mock pipeline).

# ── OpenAI (vision: ad-surface detection + video-prompt authoring) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Gemini / Nano Banana (design-file image generation) ──
GEMINI_API_KEY=
# Nano Banana Pro (default, best logo/text fidelity): gemini-3-pro-image-preview
# Nano Banana 2 (faster):                              gemini-3.1-flash-image-preview
IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Video provider selection ──
# "veo" (default; supports reference_images + first/last frame) or "kling"
VIDEO_PROVIDER=veo

# ── Veo 3.1 (default video model; Gemini API, API-key auth) ──
# Falls back to GEMINI_API_KEY if VEO_API_KEY is unset.
VEO_API_KEY=
VEO_MODEL=veo-3.1-generate-preview
# VEO_BASE_URL=https://generativelanguage.googleapis.com

# ── Kling (fallback video model; HS256 JWT auth) ──
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_MODEL=kling-v3
KLING_MODE=pro
KLING_CFG_SCALE=0.5
KLING_BASE_URL=https://api-singapore.klingai.com

# ── Dev throttle: which cuts to actually render (0-based indices). ──
# Unset/empty = all three cuts. "0" = first cut only (cheap dev). "0,1,2" = all.
NEXT_PUBLIC_GENERATE_CUTS=0
