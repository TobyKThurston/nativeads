# NativeAds — environment template. Copy to .env.local and fill what you have.
# The app runs end-to-end with NONE of these set (heuristics + mock pipeline).

# ── OpenAI (vision: ad-surface detection + video-prompt authoring) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Gemini (ONE key for BOTH Nano Banana images + Veo 3.1 video) ──
# Nano Banana (image) and Veo 3.1 (video) are Gemini-family models on the same
# Gemini API, so they share this single credential.
# ⚠ Must be a PAID-TIER key: Veo 3.1 is paid preview — the free tier won't render
#   video (image gen may work on free, but video will fail).
GEMINI_API_KEY=
# TODO confirm exact Gemini image model id (do not guess); preview ids drift.
IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Video provider selection ──
# "veo" (default; supports reference_images + first/last frame) or "kling"
VIDEO_PROVIDER=veo

# ── Veo 3.1 (default video model; uses GEMINI_API_KEY above) ──
VEO_MODEL=veo-3.1-generate-preview
# VEO_BASE_URL=https://generativelanguage.googleapis.com

# ── Preview rate limit (Gemini/Veo) ──
# Veo 3.1 preview caps are LOW (~10 RPM, plus a limit on videos per request) and
# vary by tier. The client staggers cut dispatch to stay under this; raise it on
# a higher-tier key for snappier generation.
NEXT_PUBLIC_GEMINI_RPM=10

# ── Kling (fallback video model; HS256 JWT auth) ──
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_MODEL=kling-v3
KLING_MODE=pro
KLING_CFG_SCALE=0.5
KLING_BASE_URL=https://api-singapore.klingai.com

# ── Dev throttle: which cuts to actually render (0-based indices). ──
# Unset/empty = all three cuts. "0" = first cut only (cheap dev). "0,1,2" = all.
NEXT_PUBLIC_GENERATE_CUTS=0
